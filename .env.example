# ─── General ──────────────────────────────────────────────────────────────────
ENV=development

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Supported values: ollama | bedrock
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_ID=llama3.1

# Amazon Bedrock (used when LLM_PROVIDER=bedrock)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# ─── Vector Store ─────────────────────────────────────────────────────────────
VECTOR_STORE=chroma

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_ENDPOINT_URL=http://localhost:8001
DYNAMODB_TABLE_USER_PROFILES=UserProfiles

# ─── AWS Credentials ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# For local development with DynamoDB Local, dummy values are sufficient.
# For Bedrock or production DynamoDB, replace with real credentials or use IAM roles.
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
