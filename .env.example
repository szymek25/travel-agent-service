# ─── General ──────────────────────────────────────────────────────────────────
ENV=development

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Supported values: ollama | bedrock
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
# Global default model — used when no per-agent override is set
OLLAMA_MODEL_ID=llama3.1
# Per-agent overrides (leave empty to fall back to OLLAMA_MODEL_ID)
#OLLAMA_MODEL_ID_TRAVEL_AGENT=
#OLLAMA_MODEL_ID_EXTRACTOR_AGENT=
#OLLAMA_MODEL_ID_RECOMMENDATIONS_AGENT=

# Amazon Bedrock (used when LLM_PROVIDER=bedrock)
# Global default model
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
# Per-agent overrides (leave empty to fall back to BEDROCK_MODEL_ID)
#BEDROCK_MODEL_ID_TRAVEL_AGENT=
#BEDROCK_MODEL_ID_EXTRACTOR_AGENT=
#BEDROCK_MODEL_ID_RECOMMENDATIONS_AGENT=

# ─── Session Management ──────────────────────────────────────────────────────
# Local filesystem path for FileSessionManager session storage.
# When deploying to AWS, this is replaced by S3SessionManager.
SESSION_STORAGE_DIR=/tmp/travel-agent-sessions

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_ENDPOINT_URL=http://localhost:8001
DYNAMODB_TABLE_USER_PROFILES=UserProfiles

# ─── AWS Credentials ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# For local development with DynamoDB Local, dummy values are sufficient.
# For Bedrock or production DynamoDB, replace with real credentials or use IAM roles.
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
